# EOLES-Dispatch environment variables
# Copy this file to .env and fill in your values.

# ENTSO-E Transparency Platform API key (required for data collection).
# Register for free at https://transparency.entsoe.eu/
# Go to: My Account > Web API Security Token
ENTSOE_API_KEY=your-api-key-here

# Elexon BMRS: no API key needed (public API).
# Renewables.ninja: no API key needed (public downloads).
